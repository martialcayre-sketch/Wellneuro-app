{
  "name": "wellneuro-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run prisma:generate && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link --project-ref $SUPABASE_PROJECT_REF",
    "supabase:db:pull": "supabase db pull",
    "supabase:db:push": "supabase db push",
    "supabase:migration:new": "supabase migration new",
    "setup:check": "npm run prisma:generate && npm run type-check && npm run scoring-check",
    "scoring-check": "node ../scripts/check_questionnaire_certification.js",
    "backfill:pack-registry:dry-run": "node prisma/runWithAlias.js prisma/backfillQuestionnaireRegistry.ts --dry-run",
    "backfill:pack-registry:apply": "node prisma/runWithAlias.js prisma/backfillQuestionnaireRegistry.ts --apply",
    "check:pack-registry": "node prisma/runWithAlias.js prisma/checkPackRegistryConsistency.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "nodemailer": "^7.0.13",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5"
  }
}
