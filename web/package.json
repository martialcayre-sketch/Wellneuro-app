{
  "name": "wellneuro-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "bash scripts/vercel-build.sh",
    "start": "next start",
    "start:scalingo": "next start -p ${PORT:-3000}",
    "db:deploy": "bash scripts/db-deploy.sh",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link --project-ref $SUPABASE_PROJECT_REF",
    "supabase:db:pull": "supabase db pull",
    "supabase:db:push": "supabase db push",
    "supabase:migration:new": "supabase migration new",
    "setup:check": "npm run prisma:generate && npm run type-check && npm run scoring-check",
    "scoring-check": "node ../scripts/check_questionnaire_certification.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:dot": "vitest run --reporter=dot",
    "test:changed": "vitest run --changed origin/main --reporter=dot",
    "check": "npm run type-check && npm run lint && npm run test:changed && bash ../scripts/check_no_secrets.sh --staged",
    "test:e2e": "playwright test",
    "test:worktree": "bash ../scripts/wn-test-worktree.sh",
    "backfill:pack-registry:dry-run": "node prisma/runWithAlias.js prisma/backfillQuestionnaireRegistry.ts --dry-run",
    "backfill:pack-registry:apply": "node prisma/runWithAlias.js prisma/backfillQuestionnaireRegistry.ts --apply",
    "check:pack-registry": "node prisma/runWithAlias.js prisma/checkPackRegistryConsistency.ts",
    "c5:ciqual:dry-run": "node prisma/runWithAlias.js prisma/importCiqual2025.ts",
    "c5:ciqual:apply": "node prisma/runWithAlias.js prisma/importCiqual2025.ts --apply",
    "c5:ciqual:test-integration": "bash scripts/test-c5-ciqual-import.sh",
    "prompt-cache-check": "node prisma/runWithAlias.js scripts/prompt-cache-check.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@sentry/nextjs": "^10.65.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "lucide-react": "^1.24.0",
    "next": "14.2.35",
    "next-auth": "^4.24.7",
    "nodemailer": "^7.0.13",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.2",
    "saxes": "6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@prisma/dev": "0.24.14"
  }
}
