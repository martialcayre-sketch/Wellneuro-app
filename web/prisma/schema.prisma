generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id             String   @id @default(cuid())
  idPatient      String   @unique @map("id_patient")
  email          String   @unique @map("email")
  prenom         String   @map("prenom")
  nom            String   @map("nom")
  dateNaissance  String?  @map("date_naissance")
  telephone      String?  @map("telephone")
  praticienEmail String   @map("praticien_email")
  actif          Boolean  @default(true) @map("actif")

  // Clôture de suivi (IDP2) — le dossier reste, le patient garde sa LECTURE,
  // et plus aucun questionnaire ne lui est assigné ni document envoyé.
  // DISTINCT de `actif` : `actif: false` coupe l'accès au portail (voir
  // `api/portail/lien/demande`), ce que la clôture ne doit précisément pas
  // faire. Réversible : la reprise remet le champ à null.
  suiviClotureLe DateTime? @map("suivi_cloture_le")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Token d'accès permanent au portail patient (/portail/[token]).
  // Révocable par le praticien ou sur demande du patient. La reconnexion se
  // fait via ce token + l'email pré-enregistré (email = second facteur).
  accessToken          String?   @unique @map("access_token")
  accessTokenRevoked   Boolean   @default(false) @map("access_token_revoked")
  accessTokenCreatedAt DateTime? @map("access_token_created_at")

  // Coupe-circuit de session, propre au COMPTE et non au jeton (IDP2 LOT-02).
  // Toute session portail émise avant cette date est refusée. Distinct de
  // `accessTokenRevoked`, qui ne vit que tant que le jeton permanent existe :
  // ce champ survit à son retrait (LOT-04). Une révocation pose les deux ; une
  // réémission ne défait que le premier.
  sessionsInvalidesAvant DateTime? @map("sessions_invalides_avant")

  assignations          Assignation[]
  questionnaireReponses QuestionnaireReponse[]
  synthesiesIA          SyntheseIA[]
  consultations         Consultation[]

  trustAcknowledgements     TrustAcknowledgement[]
  trustChoiceEvents         TrustChoiceEvent[]
  trustAdverseEffectReports TrustAdverseEffectReport[]
  trustPrivacyIncidents     TrustPrivacyIncident[]
  trustRightsRequests       TrustRightsRequest[]

  assessmentEpisodes         AssessmentEpisode[]
  protocolDrafts             ProtocolDraft[]
  protocolCheckins           ProtocolCheckin[]
  protocolDiffusionApprovals ProtocolDiffusionApproval[]
  relectureNotes             RelectureNote[]
  filCardRejections          FilCardRejection[]
  portailMagicLinks          PortailMagicLink[]
  packPropositions           PackProposition[]
  correspondancesMedecin     CorrespondanceMedecin[]

  @@map("patients")
}

// Consultation : dossier d'onboarding d'un patient (historisable — N par
// patient). Porte le consentement, la fiche signalétique, l'anamnèse et le
// motif. À la validation, déclenche l'assignation du pack de base.
model Consultation {
  id             String @id @default(cuid())
  idConsultation String @unique @map("id_consultation")
  idPatient      String @map("id_patient")
  emailPatient   String @map("email_patient")
  praticienEmail String @map("praticien_email")

  // creee -> en_cours -> validee
  statut String  @default("creee") @map("statut")
  motif  String? @map("motif")

  consentement           String    @default("non_donne") @map("consentement")
  consentementHorodatage DateTime? @map("consentement_horodatage")
  consentementVersion    String?   @map("consentement_version")
  // P6 : finalité du consentement (portée RGPD du recueil au niveau consultation).
  finaliteConsentement   String?   @map("finalite_consentement")

  ficheSignaletique Json? @map("fiche_signaletique")
  anamnese          Json? @map("anamnese")

  dateValidation DateTime? @map("date_validation")
  idPackAssigne  String?   @map("id_pack_assigne")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@map("consultations")
}

model Assignation {
  id              String   @id @default(cuid())
  idAssignation   String   @unique @map("id_assignation")
  idPatient       String   @map("id_patient")
  emailPatient    String   @map("email_patient")
  idQuestionnaire String   @map("id_questionnaire")
  titre           String   @map("titre")
  dateAssignation DateTime @default(now()) @map("date_assignation")
  dateLimite      String?  @map("date_limite")
  statut          String   @default("En attente") @map("statut")
  notes           String?  @map("notes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  consentement             String    @default("non_donne") @map("consentement")
  consentementHorodatage   DateTime? @map("consentement_horodatage")
  consentementVersion      String?   @map("consentement_version")
  consentementRetraitDate  DateTime? @map("consentement_retrait_date")
  statutReponses           String    @default("non_rempli") @map("statut_reponses")
  dateDerniereModification DateTime? @map("date_derniere_modification")

  // P6 : consultation dont le consentement (finalité/version/horodatage) couvre
  // cette assignation. Lien souple par id métier (comme idPackAssigne), sans FK.
  idConsultation String? @map("id_consultation")

  // P5 : demande de correction — commentaire facultatif du patient + horodatage.
  correctionCommentaire  String?   @map("correction_commentaire")
  correctionDemandeeDate DateTime? @map("correction_demandee_date")

  patient          Patient           @relation(fields: [idPatient], references: [idPatient])
  protocolCheckins ProtocolCheckin[]

  @@map("assignations")
}

// Pack : bundle nommé de questionnaires (qids) assignable en une fois à un
// patient. Éditable en base par le praticien. Portage du modèle GAS legacy
// (feuille « Packs » : ID_Pack, Nom, Thématique, Description, QIDs_JSON, Actif).
model Pack {
  id          String   @id @default(cuid())
  idPack      String   @unique @map("id_pack")
  nom         String   @map("nom")
  thematique  String?  @map("thematique")
  description String?  @map("description")
  qids        String[] @default([]) @map("qids")
  actif       Boolean  @default(true) @map("actif")
  // Pack de base assigné automatiquement en fin d'onboarding (« BASE DE
  // CONSULTATION »). Un seul pack parDefaut actif à la fois (garanti applicativement).
  parDefaut   Boolean  @default(false) @map("par_defaut")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("packs")
}

// Registre normalisé questionnaires/catégories/packs (phase 2).
// Ne remplace pas immédiatement la table legacy `packs`; sert de base pour
// migration progressive vers un modèle relationnel traçable.
model QuestionnaireCategory {
  id             String   @id @default(cuid())
  code           String   @unique @map("code")
  labelFr        String   @map("label_fr")
  description    String?  @map("description")
  ordreAffichage Int      @default(0) @map("ordre_affichage")
  actif          Boolean  @default(true) @map("actif")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  questionnairesPrincipaux QuestionnaireDefinition[]
  secondaires              QuestionnaireSecondaryCategory[]

  @@map("questionnaire_categories")
}

model QuestionnaireDefinition {
  id                    String   @id @default(cuid())
  questionnaireId       String   @unique @map("questionnaire_id")
  slug                  String   @unique @map("slug")
  titre                 String   @map("titre")
  categoriePrincipaleId String   @map("categorie_principale_id")
  niveau                String   @map("niveau")
  publicCible           String   @map("public_cible")
  versionPatient        Boolean  @default(true) @map("version_patient")
  versionPro            Boolean  @default(true) @map("version_pro")
  sourceMdPath          String?  @map("source_md_path")
  conversionJson        Boolean  @default(true) @map("conversion_json")
  actif                 Boolean  @default(true) @map("actif")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  categoriePrincipale   QuestionnaireCategory            @relation(fields: [categoriePrincipaleId], references: [id])
  categoriesSecondaires QuestionnaireSecondaryCategory[]
  packItems             QuestionnairePackQuestionnaire[]

  @@index([questionnaireId])
  @@index([categoriePrincipaleId])
  @@map("questionnaires")
}

model QuestionnaireSecondaryCategory {
  id              String   @id @default(cuid())
  questionnaireId String   @map("questionnaire_id")
  categorieId     String   @map("categorie_id")
  createdAt       DateTime @default(now()) @map("created_at")

  questionnaire QuestionnaireDefinition @relation(fields: [questionnaireId], references: [id])
  categorie     QuestionnaireCategory   @relation(fields: [categorieId], references: [id])

  @@unique([questionnaireId, categorieId])
  @@index([categorieId])
  @@map("questionnaire_secondary_categories")
}

model QuestionnairePack {
  id             String   @id @default(cuid())
  packId         String   @unique @map("pack_id")
  titre          String   @map("titre")
  description    String?  @map("description")
  niveau         String   @map("niveau")
  usageClinique  String?  @map("usage_clinique")
  ordreAffichage Int      @default(0) @map("ordre_affichage")
  actif          Boolean  @default(true) @map("actif")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  questionnaires QuestionnairePackQuestionnaire[]
  triggers       QuestionnairePackTrigger[]

  @@map("questionnaire_packs")
}

model QuestionnairePackQuestionnaire {
  id                 String   @id @default(cuid())
  packId             String   @map("pack_id")
  questionnaireId    String   @map("questionnaire_id")
  ordre              Int      @default(0) @map("ordre")
  obligatoire        Boolean  @default(true) @map("obligatoire")
  conditionAffichage Json?    @map("condition_affichage")
  createdAt          DateTime @default(now()) @map("created_at")

  pack          QuestionnairePack       @relation(fields: [packId], references: [id])
  questionnaire QuestionnaireDefinition @relation(fields: [questionnaireId], references: [id])

  @@unique([packId, questionnaireId])
  @@index([questionnaireId])
  @@map("pack_questionnaires")
}

model QuestionnairePackTrigger {
  id          String   @id @default(cuid())
  packId      String   @map("pack_id")
  triggerType String   @map("trigger_type")
  triggerKey  String   @map("trigger_key")
  operator    String   @map("operator")
  valueJson   Json?    @map("value_json")
  valueText   String?  @map("value_text")
  priority    Int      @default(0) @map("priority")
  actif       Boolean  @default(true) @map("actif")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  pack QuestionnairePack @relation(fields: [packId], references: [id])

  @@index([packId])
  @@index([triggerType, triggerKey])
  @@map("pack_triggers")
}

model QuestionnaireReponse {
  id              String   @id @default(cuid())
  idReponse       String   @unique @map("id_reponse")
  idPatient       String   @map("id_patient")
  emailPatient    String   @map("email_patient")
  idAssignation   String?  @map("id_assignation")
  idQuestionnaire String   @map("id_questionnaire")
  titre           String   @map("titre")
  dateReponse     DateTime @default(now()) @map("date_reponse")
  scoresJson      Json     @map("scores_json")
  scorePrincipal  Float?   @map("score_principal")
  interpretation  String?  @map("interpretation")
  createdAt       DateTime @default(now()) @map("created_at")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@map("questionnaire_reponses")
}

model SyntheseIA {
  id             String    @id @default(cuid())
  idSynthese     String    @unique @map("id_synthese")
  idPatient      String    @map("id_patient")
  emailPatient   String    @map("email_patient")
  dateGeneration DateTime  @default(now()) @map("date_generation")
  modele         String    @map("modele")
  versionPrompt  String    @default("v1") @map("version_prompt")
  donneesEntree  Json      @map("donnees_entree")
  syntheseJson   Json      @map("synthese_json")
  statut         String    @default("Brouillon_IA") @map("statut")
  dateValidation DateTime? @map("date_validation")
  notesPraticien String?   @map("notes_praticien")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  patient       Patient         @relation(fields: [idPatient], references: [idPatient])
  auditEntrees  AuditSynthese[]
  bookletEnvois BookletEnvoi[]

  @@map("syntheses_ia")
}

model AuditSynthese {
  id             String   @id @default(cuid())
  dateGeneration DateTime @default(now()) @map("date_generation")
  idSynthese     String   @map("id_synthese")
  idPatient      String   @map("id_patient")
  modele         String   @map("modele")
  versionPrompt  String   @map("version_prompt")
  statut         String   @map("statut")
  erreurCourte   String?  @map("erreur_courte")

  synthese SyntheseIA @relation(fields: [idSynthese], references: [idSynthese])

  @@map("audit_syntheses")
}

model BookletEnvoi {
  id                 String   @id @default(cuid())
  dateEnvoi          DateTime @default(now()) @map("date_envoi")
  idSynthese         String   @map("id_synthese")
  idPatient          String   @map("id_patient")
  emailPatientMasque String   @map("email_patient_masque")
  statut             String   @map("statut")
  operation          String   @map("operation")
  relectureConfirmee Boolean  @default(false) @map("relecture_confirmee")
  erreurCourte       String?  @map("erreur_courte")

  synthese SyntheseIA @relation(fields: [idSynthese], references: [idSynthese])

  @@map("booklet_envois")
}

// Boussole alimentaire — couche clinique propriétaire (référentiel, aucune
// donnée patient). Cf. docs/claude/BOUSSOLE_ALIMENTAIRE_CONTEXTE.md §2.2, §5.2.
model NeuroAxis {
  id             String   @id @default(cuid())
  axisCode       String   @map("axis_code")
  labelPatient   String   @map("label_patient")
  labelPraticien String   @map("label_praticien")
  description    String?  @map("description")
  besoinNiveau1  Int?     @map("besoin_niveau1")
  besoinNiveau2  Int?     @map("besoin_niveau2")
  niveauPreuve   String   @map("niveau_preuve")
  versionMapping String   @default("v1") @map("version_mapping")
  actif          Boolean  @default(true) @map("actif")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  poids NutrientAxisWeight[]

  @@unique([axisCode, versionMapping], map: "neuro_axis_axis_version_key")
  @@map("neuro_axis")
}

model NutrientAxisWeight {
  id             String   @id @default(cuid())
  axisCode       String   @map("axis_code")
  nutrientCode   String   @map("nutrient_code")
  direction      String   @map("direction")
  poids          Float    @map("poids")
  cofacteurGroup String?  @map("cofacteur_group")
  sourceRef      String   @map("source_ref")
  seuilReference String?  @map("seuil_reference")
  versionMapping String   @default("v1") @map("version_mapping")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  neuroAxis NeuroAxis @relation(fields: [axisCode, versionMapping], references: [axisCode, versionMapping])

  @@unique([axisCode, versionMapping, nutrientCode], map: "nutrient_axis_weight_axis_version_nutrient_key")
  @@map("nutrient_axis_weight")
}

// Valeurs officielles Ciqual — référentiel C5A versionné, sans donnée patient.
// Les contraintes de statut/valeur/unité et la posture RLS deny-all sont
// renforcées dans la migration SQL LOT-02.
model CiqualNutrientValue {
  id             String   @id @default(cuid())
  ciqualCode     String   @map("ciqual_code")
  nutrientCode   String   @map("nutrient_code")
  value          Decimal? @db.Decimal(14, 6)
  valueStatus    String   @map("value_status")
  unit           String
  datasetVersion String   @map("dataset_version")
  sourceRef      String   @map("source_ref")
  sourceHash     String   @map("source_hash")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([datasetVersion, ciqualCode, nutrientCode], map: "ciqual_nutrient_values_dataset_food_nutrient_key")
  @@index([datasetVersion, ciqualCode], map: "ciqual_nutrient_values_dataset_food_idx")
  @@map("ciqual_nutrient_values")
}

// Moteur d'intention clinique — couche clinique propriétaire (référentiel,
// aucune donnée patient). V1 simplifiée : mapping direct 1 ingrédient par
// règle, sans options interchangeables ni conflits symétriques (différés
// V2). Cf. docs/claude/MOTEUR_INTENTION_CLINIQUE_CONTEXTE.md.

model SupplementIngredient {
  id        String   @id @default(cuid())
  code      String   @unique @map("code")
  nomFr     String   @map("nom_fr")
  actif     Boolean  @default(true) @map("actif")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  formes               SupplementIngredientForme[]
  clinicalRules        ClinicalRule[]
  functionalThresholds IngredientFunctionalThreshold[]

  @@map("supplement_ingredients")
}

model SupplementIngredientForme {
  id           String   @id @default(cuid())
  ingredientId String   @map("ingredient_id")
  code         String   @map("code")
  labelFr      String   @map("label_fr")
  actif        Boolean  @default(true) @map("actif")
  createdAt    DateTime @default(now()) @map("created_at")

  ingredient    SupplementIngredient @relation(fields: [ingredientId], references: [id])
  clinicalRules ClinicalRule[]

  @@unique([ingredientId, code])
  @@map("supplement_ingredient_formes")
}

model SupplementSourceReference {
  id        String   @id @default(cuid())
  citation  String   @map("citation")
  lienUrl   String?  @map("lien_url")
  actif     Boolean  @default(true) @map("actif")
  createdAt DateTime @default(now()) @map("created_at")

  clinicalRules        ClinicalRule[]
  functionalThresholds IngredientFunctionalThreshold[]

  @@map("supplement_source_references")
}

model SupplementSafetyAlert {
  id           String   @id @default(cuid())
  code         String   @unique @map("code")
  messageFr    String   @map("message_fr")
  niveauAlerte String   @map("niveau_alerte")
  actif        Boolean  @default(true) @map("actif")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  functionalThresholds IngredientFunctionalThreshold[]

  @@map("supplement_safety_alerts")
}

model ClinicalIntentTag {
  id            String   @id @default(cuid())
  code          String   @unique @map("code")
  labelFr       String   @map("label_fr")
  categorie     String   @map("categorie")
  synonymes     String[] @default([]) @map("synonymes")
  actif         Boolean  @default(true) @map("actif")
  notesInternes String?  @map("notes_internes")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  clinicalRules ClinicalRule[]

  @@index([categorie])
  @@map("clinical_intent_tags")
}

model ClinicalCriterion {
  id        String   @id @default(cuid())
  code      String   @unique @map("code")
  labelFr   String   @map("label_fr")
  categorie String?  @map("categorie")
  actif     Boolean  @default(true) @map("actif")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("clinical_criteria")
}

model FunctionalCategory {
  id          String   @id @default(cuid())
  code        String   @unique @map("code")
  labelFr     String   @map("label_fr")
  description String?  @map("description")
  actif       Boolean  @default(true) @map("actif")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  functionalThresholds IngredientFunctionalThreshold[]

  @@map("functional_categories")
}

model ClinicalRule {
  id                      String @id @default(cuid())
  intentTagId             String @map("intent_tag_id")
  typeRegle               String @map("type_regle")
  poids                   Int    @map("poids")
  justification           String @map("justification")
  conditionSupplementaire Json?  @map("condition_supplementaire")

  ingredientId            String  @map("ingredient_id")
  formePrefereeId         String? @map("forme_preferee_id")
  doseCibleBasse          Float?  @map("dose_cible_basse")
  doseCibleHaute          Float?  @map("dose_cible_haute")
  gradePreuveScientifique String  @map("grade_preuve_scientifique")
  sourceReferenceId       String  @map("source_reference_id")

  versionRegle Int       @default(1) @map("version_regle")
  actif        Boolean   @default(true) @map("actif")
  creeLe       DateTime  @default(now()) @map("cree_le")
  validePar    String?   @map("valide_par")
  valideLe     DateTime? @map("valide_le")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  intentTag       ClinicalIntentTag          @relation(fields: [intentTagId], references: [id])
  ingredient      SupplementIngredient       @relation(fields: [ingredientId], references: [id])
  formePreferee   SupplementIngredientForme? @relation(fields: [formePrefereeId], references: [id])
  sourceReference SupplementSourceReference  @relation(fields: [sourceReferenceId], references: [id])

  @@index([intentTagId])
  @@index([ingredientId])
  @@map("clinical_rules")
}

model IngredientFunctionalThreshold {
  id                       String   @id @default(cuid())
  ingredientId             String   @map("ingredient_id")
  categorieFonctionnelleId String   @map("categorie_fonctionnelle_id")
  seuilDoseBasse           Float?   @map("seuil_dose_basse")
  seuilDoseHaute           Float?   @map("seuil_dose_haute")
  unite                    String   @map("unite")
  contexteAdditionnel      Json?    @map("contexte_additionnel")
  gradePreuveScientifique  String   @map("grade_preuve_scientifique")
  sourceReferenceId        String   @map("source_reference_id")
  basculeRisque            Boolean  @default(false) @map("bascule_risque")
  safetyAlertId            String?  @map("safety_alert_id")
  actif                    Boolean  @default(true) @map("actif")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  ingredient             SupplementIngredient      @relation(fields: [ingredientId], references: [id])
  categorieFonctionnelle FunctionalCategory        @relation(fields: [categorieFonctionnelleId], references: [id])
  sourceReference        SupplementSourceReference @relation(fields: [sourceReferenceId], references: [id])
  safetyAlert            SupplementSafetyAlert?    @relation(fields: [safetyAlertId], references: [id])

  @@index([ingredientId, categorieFonctionnelleId])
  @@map("ingredient_functional_thresholds")
}

model ProtocolReviewFlag {
  id                     String    @id @default(cuid())
  protocolDraftId        String    @map("protocol_draft_id")
  typeFlag               String    @map("type_flag")
  ingredientsConcernes   String[]  @default([]) @map("ingredients_concernes")
  niveauAlerte           String    @map("niveau_alerte")
  message                String    @map("message")
  suggestionAction       String    @map("suggestion_action")
  statut                 String    @default("ouvert") @map("statut")
  justificationPraticien String?   @map("justification_praticien")
  traitePar              String?   @map("traite_par")
  traiteLe               DateTime? @map("traite_le")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@index([protocolDraftId])
  @@map("protocol_review_flags")
}

// ─── TRUST V1 (campagne 2026-07-15-trust-information-patient-droits-v1) ─────
// Traçabilité du cadre d'information patient (migration trust_v1, confirmée
// explicitement par l'utilisateur le 2026-07-16). Tables ADDITIVES et
// append-only : les événements (accusés, choix) ne sont jamais modifiés ni
// supprimés ; seuls les statuts de traitement praticien des signalements
// évoluent.

// Accusé de lecture d'une version de document d'information — « j'ai pris
// connaissance », distinct de toute autorisation. La version et son hash
// (lib/trust/contenus/registre.ts) prouvent quel texte a été présenté.
model TrustAcknowledgement {
  id              String   @id @default(cuid())
  idPatient       String   @map("id_patient")
  documentKey     String   @map("document_key")
  documentVersion String   @map("document_version")
  contentHash     String   @map("content_hash")
  type            String   @map("type") // presente | pris_connaissance
  canal           String   @default("portail") @map("canal")
  acteurRole      String   @default("patient") @map("acteur_role")
  createdAt       DateTime @default(now()) @map("created_at")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@unique([idPatient, documentKey, documentVersion, type], map: "trust_ack_patient_doc_version_type_key")
  @@map("trust_acknowledgements")
}

// Événement de choix facultatif — append-only : un retrait n'écrase jamais
// l'accord précédent, il le supplante (supersedesEventId).
model TrustChoiceEvent {
  id                String   @id @default(cuid())
  idPatient         String   @map("id_patient")
  finalite          String   @map("finalite") // partage_medecin_traitant | communications_non_essentielles
  statut            String   @map("statut") // accorde | refuse | retire
  documentVersion   String   @map("document_version")
  supersedesEventId String?  @map("supersedes_event_id")
  acteurRole        String   @default("patient") @map("acteur_role")
  enregistreLe      DateTime @default(now()) @map("enregistre_le")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@index([idPatient, finalite], map: "trust_choice_patient_finalite_idx")
  @@map("trust_choice_events")
}

// Signalement d'effet indésirable suspecté — tel que déclaré par le patient,
// sans déduction de causalité. L'orientation est produite par la règle
// déterministe versionnée (lib/trust/securite.ts) et tracée avec sa version.
model TrustAdverseEffectReport {
  id                   String    @id @default(cuid())
  idPatient            String    @map("id_patient")
  produitLibelle       String    @map("produit_libelle")
  doseDeclaree         String?   @map("dose_declaree")
  debutPrise           String?   @map("debut_prise")
  symptomes            String    @map("symptomes")
  debutSymptomes       String?   @map("debut_symptomes")
  produitsConcomitants String?   @map("produits_concomitants")
  actionPrise          String    @default("ne_sait_pas") @map("action_prise") // aucune | reduit | arrete | ne_sait_pas
  severiteDeclaree     String    @map("severite_declaree") // legere | moderee | severe | incertaine
  orientation          String    @map("orientation")
  regleId              String    @map("regle_id")
  regleVersion         String    @map("regle_version")
  statutTraitement     String    @default("recu") @map("statut_traitement") // recu | en_cours | traite | clos
  examineLe            DateTime? @map("examine_le")
  soumisLe             DateTime  @default(now()) @map("soumis_le")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@index([statutTraitement], map: "trust_aer_statut_idx")
  @@map("trust_adverse_effect_reports")
}

// Incident de confidentialité signalé par le patient.
model TrustPrivacyIncident {
  id               String    @id @default(cuid())
  idPatient        String    @map("id_patient")
  categorie        String    @map("categorie")
  description      String    @map("description")
  statutTraitement String    @default("recu") @map("statut_traitement")
  examineLe        DateTime? @map("examine_le")
  soumisLe         DateTime  @default(now()) @map("soumis_le")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@index([statutTraitement], map: "trust_incident_statut_idx")
  @@map("trust_privacy_incidents")
}

// Demande d'exercice de droits — l'interface ne promet jamais un droit
// absolu ; chaque demande reçoit une réponse expliquant ce qui est possible.
model TrustRightsRequest {
  id               String    @id @default(cuid())
  idPatient        String    @map("id_patient")
  type             String    @map("type") // acces | rectification | effacement | limitation | opposition | portabilite | retrait_choix | information
  description      String?   @map("description")
  statutTraitement String    @default("recu") @map("statut_traitement")
  reponse          String?   @map("reponse")
  examineLe        DateTime? @map("examine_le")
  soumisLe         DateTime  @default(now()) @map("soumis_le")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@index([statutTraitement], map: "trust_droits_statut_idx")
  @@map("trust_rights_requests")
}

// ─── C2A PERSISTANCE V1 (campagne 2026-07-11-suivi-j7-j14-j21-et-persistance) ─
// Persistance minimale du suivi 21 jours (migration c2a_persistance_v1, spec
// SPEC_LOT-01_MODELE_PERSISTANCE.md §8, gate confirmé par l'utilisateur le
// 2026-07-17). Tables ADDITIVES. Snapshot/review/decision-card NON persistés
// (recalculables) ; provenance ancrée par hashes. Corrections append-only.

// Épisode d'évaluation CONFIRMÉ par le praticien (les propositions restent en
// mémoire). PK = assessmentEpisodeId du contrat C1 (provenance + idempotence).
// Pas d'input_hash moteur : l'épisode est une sélection, pas une preuve hashée.
model AssessmentEpisode {
  id              String   @id @map("id")
  idPatient       String   @map("id_patient")
  milestone       String   @map("milestone") // T0 | J21 | J42 | J90 (réf. momentum.ts)
  targetAt        DateTime @map("target_at")
  confirmedAt     DateTime @map("confirmed_at")
  payload         Json     @map("payload")
  payloadHash     String   @map("payload_hash")
  contractVersion String   @map("contract_version") // objets-cliniques-v1
  // Identité de cycle (C2B / Vague 2, gate G2). Nullables : une ligne héritée
  // non rattachable reste NULL, jamais devinée.
  cycleId         String?  @map("cycle_id")
  versionScore    String?  @map("version_score") // figé à la mesure (A8-3)
  createdAt       DateTime @default(now()) @map("created_at")

  patient        Patient         @relation(fields: [idPatient], references: [idPatient])
  protocolDrafts ProtocolDraft[]

  @@index([idPatient, milestone], map: "c2a_episode_patient_milestone_idx")
  @@index([idPatient, confirmedAt], map: "c2a_episode_patient_confirmed_idx")
  @@index([idPatient, cycleId], map: "c2b_episode_cycle_idx")
  @@map("assessment_episodes")
}

// Version append-only du protocole 21 jours. PK = protocolDraftId du contrat.
// Colonnes d'ancrage de provenance (chaîne snapshot→review→decision-card) sans
// persister les objets dérivés. Correction = nouvelle ligne (supersedesDraftId).
model ProtocolDraft {
  id                    String    @id @map("id")
  idPatient             String    @map("id_patient")
  assessmentEpisodeId   String?   @map("assessment_episode_id")
  decisionCardId        String    @map("decision_card_id")
  decisionCardInputHash String    @map("decision_card_input_hash")
  snapshotInputHash     String    @map("snapshot_input_hash")
  reviewInputHash       String    @map("review_input_hash")
  selectedPriorityId    String    @map("selected_priority_id")
  status                String    @default("draft") @map("status") // draft | practitioner_reviewed
  payload               Json      @map("payload")
  inputHash             String    @map("input_hash")
  contractVersion       String    @map("contract_version") // c1-protocol-draft-v1
  supersedesDraftId     String?   @map("supersedes_draft_id")
  reviewedAt            DateTime? @map("reviewed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  patient            Patient                     @relation(fields: [idPatient], references: [idPatient])
  episode            AssessmentEpisode?          @relation(fields: [assessmentEpisodeId], references: [id])
  checkins           ProtocolCheckin[]
  diffusionApprovals ProtocolDiffusionApproval[]

  @@index([idPatient, createdAt], map: "c2a_draft_patient_created_idx")
  @@index([decisionCardId], map: "c2a_draft_decision_card_idx")
  @@index([supersedesDraftId], map: "c2a_draft_supersedes_idx")
  @@map("protocol_drafts")
}

// Check-in patient J7/J14/J21 — instrument de pilotage, jamais un score ni un
// jalon de mesure (arbitrage A1). Écriture via session portail vérifiée
// (assignation) ; chemin legacy email-gate exclu. Append-only chaîné.
model ProtocolCheckin {
  id                  String   @id @default(cuid()) @map("id")
  idPatient           String   @map("id_patient")
  idAssignation       String   @map("id_assignation")
  protocolDraftId     String   @map("protocol_draft_id")
  pointEtape          String   @map("point_etape") // J7 | J14 | J21
  reponses            Json     @map("reponses")
  canal               String   @default("portail") @map("canal")
  supersedesCheckinId String?  @map("supersedes_checkin_id")
  soumisLe            DateTime @default(now()) @map("soumis_le")

  patient     Patient       @relation(fields: [idPatient], references: [idPatient])
  assignation Assignation   @relation(fields: [idAssignation], references: [idAssignation])
  draft       ProtocolDraft @relation(fields: [protocolDraftId], references: [id])

  @@index([idPatient, pointEtape], map: "c2a_checkin_patient_point_idx")
  @@index([protocolDraftId], map: "c2a_checkin_draft_idx")
  @@index([idAssignation], map: "c2a_checkin_assignation_idx")
  @@map("protocol_checkins")
}

// Approbation praticien « pour diffusion » (C2A LOT-03 Part B). Mapping 1:1 du
// contrat ProtocolDiffusionApproval : « Validé pour diffusion », distinct de la
// relecture (reviewed_at). Append-only chaîné (supersedes_approval_id) — jamais
// de réécriture. Ancrée par protocol_draft_input_hash : caduque dès qu'une
// nouvelle version du protocole est enregistrée. Ne déclenche AUCUN envoi
// patient (transmission différée à un lot ultérieur).
model ProtocolDiffusionApproval {
  id                     String   @id @default(cuid()) @map("id")
  idPatient              String   @map("id_patient")
  protocolDraftId        String   @map("protocol_draft_id")
  decisionCardInputHash  String   @map("decision_card_input_hash")
  protocolDraftInputHash String   @map("protocol_draft_input_hash")
  approvedAt             DateTime @map("approved_at")
  approvedBy             String   @default("practitioner") @map("approved_by")
  confirmation           String   @map("confirmation") // content_approved_for_diffusion
  supersedesApprovalId   String?  @map("supersedes_approval_id")
  createdAt              DateTime @default(now()) @map("created_at")

  patient Patient       @relation(fields: [idPatient], references: [idPatient])
  draft   ProtocolDraft @relation(fields: [protocolDraftId], references: [id])

  @@index([idPatient], map: "c2a_diffusion_patient_idx")
  @@index([protocolDraftId], map: "c2a_diffusion_draft_idx")
  @@map("protocol_diffusion_approvals")
}

// Refus d'une carte du Fil (SP-FIL, gate G1). Le garde-fou 5.0 exige qu'une
// carte soit refusable, que le refus PERSISTE (elle ne revient pas le
// lendemain) et qu'il reste RÉVERSIBLE.
//
// `carte_cle` est l'identité de la carte, ancrée sur sa ligne source (voir
// `lib/fil/cartes.ts`, `cleCarte`). Les cartes étant des projections
// recalculées à chaque ouverture, c'est cette clé — et non la carte — qui est
// désignée ici.
//
// Append-only chaîné : annuler un refus n'efface ni ne réécrit rien, c'est une
// nouvelle ligne (`refusee = false`) qui supplante la précédente. L'état courant
// est la tête de chaîne. C'est pourquoi il n'y a **pas** de contrainte d'unicité
// sur (id_patient, carte_cle) : plusieurs lignes coexistent par construction,
// et une unicité rendrait justement l'annulation impossible.
//
// Aucune ligne ne signifie « non refusée » — l'état de toutes les cartes avant
// ce gate.
model FilCardRejection {
  id                    String   @id @default(cuid()) @map("id")
  idPatient             String   @map("id_patient")
  carteCle              String   @map("carte_cle")
  refusee               Boolean  @default(true) @map("refusee")
  refusePar             String   @map("refuse_par")
  supersedesRejectionId String?  @map("supersedes_rejection_id")
  refuseLe              DateTime @default(now()) @map("refuse_le")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@index([idPatient, refuseLe], map: "g1_fil_rejection_patient_idx")
  @@index([idPatient, carteCle], map: "g1_fil_rejection_cle_idx")
  @@map("fil_card_rejections")
}

// Note de relecture (SP-TT LOT-02, gate G3). Le praticien annote un état passé
// qu'il vient de relire.
//
// DEUX DATES, jamais confondues : `instant_relu` est une DONNÉE — l'instant que
// la note commente — tandis que `cree_le` est le moment de l'écriture, toujours
// le présent, et c'est la BASE qui le pose (@default(now())), jamais
// l'appelant. On n'écrit pas dans le passé, on écrit aujourd'hui à propos du
// passé. C'est l'invariant du gate.
//
// Append-only chaîné (supersedes_note_id) : corriger une note crée une ligne,
// la précédente reste lisible. Aucune réécriture, aucune suppression.
//
// PRATICIEN SEUL : aucune surface patient ne lit cette table — garde
// structurelle dans `lib/praticien/relectureNote.test.ts`.
model RelectureNote {
  id               String   @id @default(cuid()) @map("id")
  idPatient        String   @map("id_patient")
  praticienEmail   String   @map("praticien_email")
  instantRelu      DateTime @map("instant_relu")
  texte            String   @map("texte")
  supersedesNoteId String?  @map("supersedes_note_id")
  creeLe           DateTime @default(now()) @map("cree_le")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@index([idPatient, creeLe], map: "sptt_relecture_note_patient_idx")
  @@map("relecture_notes")
}

// Fil de correspondance médecin (C3 LOT-06, V1 = transcription praticien —
// décision FM-1 du cadrage du 2026-07-22). Le médecin n'accède à RIEN et
// l'application n'envoie RIEN : le praticien consigne un envoi fait par ses
// canaux habituels (sens « sortant ») et transcrit une réponse reçue (sens
// « entrant »).
//
// MINIMISATION (données d'un tiers) : le médecin n'est désigné que par un
// libellé libre (`medecin_libelle`) — ni adresse e-mail, ni RPPS, ni compte.
// Texte seul par construction : aucun champ fichier (mur HDS, décision de
// programme — le fil transporte des échanges, jamais de pièce biologique).
//
// DEUX DATES, jamais confondues (patron RelectureNote / SP-TT) : `echange_le`
// est une DONNÉE — la date de l'échange réel, telle que transcrite,
// facultative — tandis que `consigne_le` est le moment de l'écriture, posé
// par la BASE (@default(now())), jamais par l'appelant. Une consignation est
// inantidatable.
//
// CONSERVATION ALIGNÉE DOSSIER (FM-2) : dossier clos = consignation refusée
// par la route ; effacement = deleteMany nommément dans `effacerDossier`,
// forcé par la garde structurelle d'`effacement.test.ts`.
//
// `id_synthese` est une référence SOUPLE, sans FK (patron supersedes_note_id) :
// la route vérifie existence et appartenance au POST, et l'effacement du
// dossier emporte les deux tables dans la même transaction.
model CorrespondanceMedecin {
  id             String    @id @default(cuid()) @map("id")
  idPatient      String    @map("id_patient")
  praticienEmail String    @map("praticien_email")
  sens           String    @map("sens") // sortant | entrant
  medecinLibelle String    @map("medecin_libelle")
  texte          String    @map("texte")
  idSynthese     String?   @map("id_synthese")
  echangeLe      DateTime? @map("echange_le")
  consigneLe     DateTime  @default(now()) @map("consigne_le")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@index([idPatient, consigneLe], map: "c3_correspondance_medecin_patient_idx")
  @@map("correspondances_medecin")
}

// Lien magique d'accès au portail patient (IDP LOT-01, gate G4).
//
// Remplace PROGRESSIVEMENT le jeton permanent `patients.access_token`, qui est
// conservé : les deux chemins coexistent pendant la bascule, c'est une
// exigence du registre. Cette table n'enlève rien, elle ajoute une entrée.
//
// LE JETON N'EST PAS ICI. Seule son empreinte HMAC-SHA256 est stockée
// (`lib/portail/lienMagique.ts`, `empreinteJeton`) : un dump de la base ne
// permet donc pas d'ouvrir un espace patient. L'unicité sert la recherche par
// empreinte et interdit la collision.
//
// USAGE UNIQUE : `consomme_le` passe de null à un instant, une seule fois, dans
// la même transaction que la lecture d'état — sinon deux requêtes concurrentes
// consommeraient le même lien. Le rejeu n'est pas seulement refusé, il est
// TRACÉ : `rejeux_refuses` et `derniere_tentative_le` gardent la preuve en base,
// là où un log Vercel serait purgé.
//
// Aucune ligne ne signifie « aucun lien magique émis » — l'état de tous les
// patients avant ce gate, et l'état attendu tant que le drapeau est éteint.
model PortailMagicLink {
  id                String    @id @default(cuid()) @map("id")
  idPatient         String    @map("id_patient")
  jetonEmpreinte    String    @unique @map("jeton_empreinte")
  expireLe          DateTime  @map("expire_le")
  consommeLe        DateTime? @map("consomme_le")
  creePar           String    @map("cree_par")
  creeLe            DateTime  @default(now()) @map("cree_le")
  rejeuxRefuses     Int       @default(0) @map("rejeux_refuses")
  derniereTentative DateTime? @map("derniere_tentative_le")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@index([idPatient, creeLe], map: "g4_magic_link_patient_idx")
  @@map("portail_magic_links")
}

// Tentatives de redemande de lien, comptées par origine réseau (gate G4).
//
// POURQUOI UNE TABLE ET PAS UN COMPTEUR EN MÉMOIRE : plusieurs instances
// serverless répondent en parallèle ; un compteur local ne borne rien. Et
// `portail_magic_links` ne peut pas tenir ce rôle — une adresse inconnue n'y
// crée aucune ligne, or c'est exactement la tentative à compter.
//
// AUCUNE RELATION VERS `patients`, DÉLIBÉRÉMENT. Pas de clé étrangère, pas de
// colonne d'identifiant patient : aucune jointure ne doit pouvoir relier une
// origine réseau à un dossier. La table sait combien, jamais pour qui.
//
// L'ADRESSE IP N'ENTRE PAS ICI. `empreinte_ip` est un HMAC-SHA256 (clé
// NEXTAUTH_SECRET, préfixe « portail-demande-ip: »). Les lignes se purgent
// au-delà de 24 h : passé la fenêtre de comptage, elles ne seraient plus qu'une
// trace d'origine réseau conservée sans usage.
model PortailDemandeTentative {
  id          String   @id @default(cuid()) @map("id")
  empreinteIp String   @map("empreinte_ip")
  creeLe      DateTime @default(now()) @map("cree_le")

  @@index([empreinteIp, creeLe], map: "g4_demande_ip_idx")
  @@index([creeLe], map: "g4_demande_purge_idx")
  @@map("portail_demande_tentatives")
}

// Trace durable des entrées par Google (gate G5, IDP2 LOT-03c-trace).
//
// POURQUOI. Le lien magique laisse une trace en base (`consomme_le`,
// `rejeux_refuses`) ; le chemin Google n'en laissait aucune — seulement un log
// Vercel, purgeable. La revue adversariale du 2026-07-21 en a fait un NO-GO à
// l'activation : trois mois après, « qui a ouvert ce dossier, quand, par quel
// chemin » n'aurait plus de réponse. Cette table est la réponse.
//
// CE QU'ELLE PORTE, ET CE QU'ELLE NE PORTE PAS. `id_patient` (l'identifiant
// synthétique, déjà partout ailleurs), l'instant, l'issue, et pour un refus sa
// catégorie interne. JAMAIS l'adresse e-mail, JAMAIS une empreinte, JAMAIS le
// jeton — même exigence de sobriété que `DossierEfface`. `id_patient` est
// nullable : un refus sur une adresse inconnue n'a pas de patient à nommer.
//
// SANS CLÉ ÉTRANGÈRE VERS `patients`, comme `audit_syntheses` et
// `booklet_envois`. `id_patient` est nullable (un refus sur adresse inconnue
// n'a pas de patient), et une FK sur une colonne nullable n'apporterait rien
// aux lignes sans parent. En contrepartie, rien dans la base ne protège cette
// table d'un oubli à l'effacement : c'est `effacerDossier` qui l'efface
// nommément, et `effacement.test.ts` échoue si une table portant `id_patient`
// y est oubliée. Un journal d'accès qui SURVIVRAIT à l'effacement le viderait
// de son sens — il continuerait à nommer le dossier qu'on vient de détruire.
//
// PAS DE PURGE AUTOMATIQUE, hors effacement. Contrairement à
// `portail_demande_tentatives` — un compteur de cadence sans valeur passé une
// heure — ceci est un journal d'accès : durer, tant que le dossier existe, est
// son objet. La durée de conservation générale est une décision de conformité,
// pas une constante de code : elle n'est pas encodée ici.
//
// ELLE N'EST ÉCRITE QU'APRÈS LA VÉRIFICATION DU `state`. Un retour forgé qui n'a
// pas franchi la garde anti-CSRF n'écrit aucune ligne : sans cela, marteler
// `/portail/google/retour` gonflerait la table sans borne.
model PortailConnexionGoogle {
  id        String   @id @default(cuid()) @map("id")
  idPatient String?  @map("id_patient")
  issue     String   @map("issue")
  motif     String?  @map("motif")
  creeLe    DateTime @default(now()) @map("cree_le")

  @@index([idPatient, creeLe], map: "g5_google_patient_idx")
  @@index([creeLe], map: "g5_google_scan_idx")
  @@map("portail_connexions_google")
}

// Résidu laissé par un effacement de dossier (IDP2).
//
// L'application PROMET l'effacement au patient
// (`lib/trust/contenus/registre.ts`). Quand il l'exerce, la ligne `patients` et
// ses seize tables filles sont supprimées ; il ne subsiste que cette ligne, dont
// le seul objet est que les comptages de l'historique clinique ne s'effondrent
// pas.
//
// CE QU'ELLE NE PEUT PAS CONTENIR, par construction : aucun identifiant
// patient, aucune clé étrangère, aucun prénom, aucune adresse. Le prénom
// figurait dans la décision initiale du 2026-07-21 et en a été retiré le même
// jour — sur quelques dizaines de dossiers, « prénom + trois lettres + année »
// redevenait rapprochable d'une personne, et le mot « effacement » n'aurait pas
// tenu. Même principe que `portail_demande_tentatives` : la table ne compte pas
// sur la discipline pour rester anonyme, elle en est incapable.
//
// C'est aussi la SEULE trace qu'un effacement a eu lieu : la demande
// enregistrée dans `trust_rights_requests` est supprimée par son propre
// traitement.
model DossierEfface {
  id             String   @id @default(cuid()) @map("id")
  anneeNaissance Int?     @map("annee_naissance")
  initialesNom   String   @map("initiales_nom")
  effaceLe       DateTime @default(now()) @map("efface_le")

  @@index([effaceLe], map: "idp2_dossier_efface_date_idx")
  @@map("dossiers_effaces")
}

// Proposition de pack de réévaluation (SP-SPI LOT-01). Le pack est PROPOSÉ au
// patient qui revient après une absence — jamais assigné : l'assignation reste
// un geste praticien, et cette table n'en crée aucune.
//
// POURQUOI ELLE EXISTE. Le lot s'interdisait toute écriture et exigeait en même
// temps un pack refusable. Les deux ne tiennent pas ensemble : un refus qu'on
// ne persiste pas revient à chaque visite, et une proposition qui revient EST
// une relance — ce que la campagne s'interdit explicitement. La donnée sert donc
// à NE PAS REDEMANDER, jamais à insister.
//
// CE QU'ELLE NE DÉCLENCHE PAS : aucune assignation, aucun envoi d'e-mail, aucun
// compte à rebours, aucune relance. Un refus reste sans conséquence pour le
// patient — c'est un invariant de la campagne, pas une propriété de cette table.
//
// Append-only chaîné (supersedes_proposition_id), comme `trust_choice_events` et
// `fil_card_rejections` : répondre à une proposition crée une SECONDE ligne qui
// supplante la première, laquelle reste lisible. Aucune réécriture, aucune
// suppression, et donc aucune contrainte d'unicité sur (id_patient, id_pack) —
// elle rendrait la réponse impossible. Les index servent la lecture seule.
//
// `id_pack` n'est PAS une clé étrangère vers `packs` : la proposition consigne
// ce qui a été proposé au moment où ça l'a été, et doit survivre à la
// désactivation du pack — même raison que `version_score` figée à la mesure.
model PackProposition {
  id                      String   @id @default(cuid()) @map("id")
  idPatient               String   @map("id_patient")
  idPack                  String   @map("id_pack")
  statut                  String   @map("statut") // proposee | acceptee | declinee
  // « systeme » pose la proposition, « patient » y répond. Jamais déduit de la
  // valeur de `statut` : qui écrit et ce qui est écrit restent deux choses.
  acteurRole              String   @map("acteur_role")
  supersedesPropositionId String?  @map("supersedes_proposition_id")
  enregistreLe            DateTime @default(now()) @map("enregistre_le")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@index([idPatient, enregistreLe], map: "sp_spi_pack_proposition_patient_idx")
  @@index([idPatient, idPack], map: "sp_spi_pack_proposition_pack_idx")
  @@map("pack_propositions")
}
