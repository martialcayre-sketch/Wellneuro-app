generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id             String   @id @default(cuid())
  idPatient      String   @unique @map("id_patient")
  email          String   @unique @map("email")
  prenom         String   @map("prenom")
  nom            String   @map("nom")
  dateNaissance  String?  @map("date_naissance")
  telephone      String?  @map("telephone")
  praticienEmail String   @map("praticien_email")
  actif          Boolean  @default(true) @map("actif")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Token d'accès permanent au portail patient (/portail/[token]).
  // Révocable par le praticien ou sur demande du patient. La reconnexion se
  // fait via ce token + l'email pré-enregistré (email = second facteur).
  accessToken          String?   @unique @map("access_token")
  accessTokenRevoked   Boolean   @default(false) @map("access_token_revoked")
  accessTokenCreatedAt DateTime? @map("access_token_created_at")

  assignations          Assignation[]
  questionnaireReponses QuestionnaireReponse[]
  synthesiesIA          SyntheseIA[]
  consultations         Consultation[]

  @@map("patients")
}

// Consultation : dossier d'onboarding d'un patient (historisable — N par
// patient). Porte le consentement, la fiche signalétique, l'anamnèse et le
// motif. À la validation, déclenche l'assignation du pack de base.
model Consultation {
  id             String @id @default(cuid())
  idConsultation String @unique @map("id_consultation")
  idPatient      String @map("id_patient")
  emailPatient   String @map("email_patient")
  praticienEmail String @map("praticien_email")

  // creee -> en_cours -> validee
  statut String  @default("creee") @map("statut")
  motif  String? @map("motif")

  consentement           String    @default("non_donne") @map("consentement")
  consentementHorodatage DateTime? @map("consentement_horodatage")
  consentementVersion    String?   @map("consentement_version")

  ficheSignaletique Json? @map("fiche_signaletique")
  anamnese          Json? @map("anamnese")

  dateValidation DateTime? @map("date_validation")
  idPackAssigne  String?   @map("id_pack_assigne")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@map("consultations")
}

model Assignation {
  id              String   @id @default(cuid())
  idAssignation   String   @unique @map("id_assignation")
  idPatient       String   @map("id_patient")
  emailPatient    String   @map("email_patient")
  idQuestionnaire String   @map("id_questionnaire")
  titre           String   @map("titre")
  dateAssignation DateTime @default(now()) @map("date_assignation")
  dateLimite      String?  @map("date_limite")
  statut          String   @default("En attente") @map("statut")
  notes           String?  @map("notes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  consentement             String    @default("non_donne") @map("consentement")
  consentementHorodatage   DateTime? @map("consentement_horodatage")
  consentementVersion      String?   @map("consentement_version")
  consentementRetraitDate  DateTime? @map("consentement_retrait_date")
  statutReponses           String    @default("non_rempli") @map("statut_reponses")
  dateDerniereModification DateTime? @map("date_derniere_modification")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@map("assignations")
}

// Pack : bundle nommé de questionnaires (qids) assignable en une fois à un
// patient. Éditable en base par le praticien. Portage du modèle GAS legacy
// (feuille « Packs » : ID_Pack, Nom, Thématique, Description, QIDs_JSON, Actif).
model Pack {
  id          String   @id @default(cuid())
  idPack      String   @unique @map("id_pack")
  nom         String   @map("nom")
  thematique  String?  @map("thematique")
  description String?  @map("description")
  qids        String[] @default([]) @map("qids")
  actif       Boolean  @default(true) @map("actif")
  // Pack de base assigné automatiquement en fin d'onboarding (« BASE DE
  // CONSULTATION »). Un seul pack parDefaut actif à la fois (garanti applicativement).
  parDefaut   Boolean  @default(false) @map("par_defaut")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("packs")
}

// Registre normalisé questionnaires/catégories/packs (phase 2).
// Ne remplace pas immédiatement la table legacy `packs`; sert de base pour
// migration progressive vers un modèle relationnel traçable.
model QuestionnaireCategory {
  id             String   @id @default(cuid())
  code           String   @unique @map("code")
  labelFr        String   @map("label_fr")
  description    String?  @map("description")
  ordreAffichage Int      @default(0) @map("ordre_affichage")
  actif          Boolean  @default(true) @map("actif")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  questionnairesPrincipaux QuestionnaireDefinition[]
  secondaires             QuestionnaireSecondaryCategory[]

  @@map("questionnaire_categories")
}

model QuestionnaireDefinition {
  id                    String   @id @default(cuid())
  questionnaireId       String   @unique @map("questionnaire_id")
  slug                  String   @unique @map("slug")
  titre                 String   @map("titre")
  categoriePrincipaleId String   @map("categorie_principale_id")
  niveau                String   @map("niveau")
  publicCible           String   @map("public_cible")
  versionPatient        Boolean  @default(true) @map("version_patient")
  versionPro            Boolean  @default(true) @map("version_pro")
  sourceMdPath          String?  @map("source_md_path")
  conversionJson        Boolean  @default(true) @map("conversion_json")
  actif                 Boolean  @default(true) @map("actif")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  categoriePrincipale QuestionnaireCategory          @relation(fields: [categoriePrincipaleId], references: [id])
  categoriesSecondaires QuestionnaireSecondaryCategory[]
  packItems             QuestionnairePackQuestionnaire[]

  @@index([questionnaireId])
  @@index([categoriePrincipaleId])
  @@map("questionnaires")
}

model QuestionnaireSecondaryCategory {
  id                String   @id @default(cuid())
  questionnaireId   String   @map("questionnaire_id")
  categorieId       String   @map("categorie_id")
  createdAt         DateTime @default(now()) @map("created_at")

  questionnaire QuestionnaireDefinition @relation(fields: [questionnaireId], references: [id])
  categorie     QuestionnaireCategory   @relation(fields: [categorieId], references: [id])

  @@unique([questionnaireId, categorieId])
  @@index([categorieId])
  @@map("questionnaire_secondary_categories")
}

model QuestionnairePack {
  id            String   @id @default(cuid())
  packId        String   @unique @map("pack_id")
  titre         String   @map("titre")
  description   String?  @map("description")
  niveau        String   @map("niveau")
  usageClinique String?  @map("usage_clinique")
  ordreAffichage Int     @default(0) @map("ordre_affichage")
  actif         Boolean  @default(true) @map("actif")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  questionnaires QuestionnairePackQuestionnaire[]
  triggers       QuestionnairePackTrigger[]

  @@map("questionnaire_packs")
}

model QuestionnairePackQuestionnaire {
  id              String   @id @default(cuid())
  packId          String   @map("pack_id")
  questionnaireId String   @map("questionnaire_id")
  ordre           Int      @default(0) @map("ordre")
  obligatoire     Boolean  @default(true) @map("obligatoire")
  conditionAffichage Json? @map("condition_affichage")
  createdAt       DateTime @default(now()) @map("created_at")

  pack          QuestionnairePack       @relation(fields: [packId], references: [id])
  questionnaire QuestionnaireDefinition @relation(fields: [questionnaireId], references: [id])

  @@unique([packId, questionnaireId])
  @@index([questionnaireId])
  @@map("pack_questionnaires")
}

model QuestionnairePackTrigger {
  id          String   @id @default(cuid())
  packId      String   @map("pack_id")
  triggerType String   @map("trigger_type")
  triggerKey  String   @map("trigger_key")
  operator    String   @map("operator")
  valueJson   Json?    @map("value_json")
  valueText   String?  @map("value_text")
  priority    Int      @default(0) @map("priority")
  actif       Boolean  @default(true) @map("actif")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  pack QuestionnairePack @relation(fields: [packId], references: [id])

  @@index([packId])
  @@index([triggerType, triggerKey])
  @@map("pack_triggers")
}

model QuestionnaireReponse {
  id              String   @id @default(cuid())
  idReponse       String   @unique @map("id_reponse")
  idPatient       String   @map("id_patient")
  emailPatient    String   @map("email_patient")
  idAssignation   String?  @map("id_assignation")
  idQuestionnaire String   @map("id_questionnaire")
  titre           String   @map("titre")
  dateReponse     DateTime @default(now()) @map("date_reponse")
  scoresJson      Json     @map("scores_json")
  scorePrincipal  Float?   @map("score_principal")
  interpretation  String?  @map("interpretation")
  createdAt       DateTime @default(now()) @map("created_at")

  patient Patient @relation(fields: [idPatient], references: [idPatient])

  @@map("questionnaire_reponses")
}

model SyntheseIA {
  id             String    @id @default(cuid())
  idSynthese     String    @unique @map("id_synthese")
  idPatient      String    @map("id_patient")
  emailPatient   String    @map("email_patient")
  dateGeneration DateTime  @default(now()) @map("date_generation")
  modele         String    @map("modele")
  versionPrompt  String    @default("v1") @map("version_prompt")
  donneesEntree  Json      @map("donnees_entree")
  syntheseJson   Json      @map("synthese_json")
  statut         String    @default("Brouillon_IA") @map("statut")
  dateValidation DateTime? @map("date_validation")
  notesPraticien String?   @map("notes_praticien")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  patient       Patient         @relation(fields: [idPatient], references: [idPatient])
  auditEntrees  AuditSynthese[]
  bookletEnvois BookletEnvoi[]

  @@map("syntheses_ia")
}

model AuditSynthese {
  id             String   @id @default(cuid())
  dateGeneration DateTime @default(now()) @map("date_generation")
  idSynthese     String   @map("id_synthese")
  idPatient      String   @map("id_patient")
  modele         String   @map("modele")
  versionPrompt  String   @map("version_prompt")
  statut         String   @map("statut")
  erreurCourte   String?  @map("erreur_courte")

  synthese SyntheseIA @relation(fields: [idSynthese], references: [idSynthese])

  @@map("audit_syntheses")
}

model BookletEnvoi {
  id                 String   @id @default(cuid())
  dateEnvoi          DateTime @default(now()) @map("date_envoi")
  idSynthese         String   @map("id_synthese")
  idPatient          String   @map("id_patient")
  emailPatientMasque String   @map("email_patient_masque")
  statut             String   @map("statut")
  operation          String   @map("operation")
  relectureConfirmee Boolean  @default(false) @map("relecture_confirmee")
  erreurCourte       String?  @map("erreur_courte")

  synthese SyntheseIA @relation(fields: [idSynthese], references: [idSynthese])

  @@map("booklet_envois")
}

// Boussole alimentaire — couche clinique propriétaire (référentiel, aucune
// donnée patient). Cf. docs/claude/BOUSSOLE_ALIMENTAIRE_CONTEXTE.md §2.2, §5.2.
model NeuroAxis {
  id             String   @id @default(cuid())
  axisCode       String   @unique @map("axis_code")
  labelPatient   String   @map("label_patient")
  labelPraticien String   @map("label_praticien")
  description    String?  @map("description")
  besoinNiveau1  Int?     @map("besoin_niveau1")
  besoinNiveau2  Int?     @map("besoin_niveau2")
  niveauPreuve   String   @map("niveau_preuve")
  versionMapping String   @default("v1") @map("version_mapping")
  actif          Boolean  @default(true) @map("actif")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  poids NutrientAxisWeight[]

  @@map("neuro_axis")
}

model NutrientAxisWeight {
  id             String   @id @default(cuid())
  axisCode       String   @map("axis_code")
  nutrientCode   String   @map("nutrient_code")
  direction      String   @map("direction")
  poids          Float    @map("poids")
  cofacteurGroup String?  @map("cofacteur_group")
  sourceRef      String   @map("source_ref")
  seuilReference String?  @map("seuil_reference")
  versionMapping String   @default("v1") @map("version_mapping")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  neuroAxis NeuroAxis @relation(fields: [axisCode], references: [axisCode])

  @@map("nutrient_axis_weight")
}

// Moteur d'intention clinique — couche clinique propriétaire (référentiel,
// aucune donnée patient). V1 simplifiée : mapping direct 1 ingrédient par
// règle, sans options interchangeables ni conflits symétriques (différés
// V2). Cf. docs/claude/MOTEUR_INTENTION_CLINIQUE_CONTEXTE.md.

model SupplementIngredient {
  id        String   @id @default(cuid())
  code      String   @unique @map("code")
  nomFr     String   @map("nom_fr")
  actif     Boolean  @default(true) @map("actif")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  formes               SupplementIngredientForme[]
  clinicalRules        ClinicalRule[]
  functionalThresholds IngredientFunctionalThreshold[]

  @@map("supplement_ingredients")
}

model SupplementIngredientForme {
  id           String   @id @default(cuid())
  ingredientId String   @map("ingredient_id")
  code         String   @map("code")
  labelFr      String   @map("label_fr")
  actif        Boolean  @default(true) @map("actif")
  createdAt    DateTime @default(now()) @map("created_at")

  ingredient    SupplementIngredient @relation(fields: [ingredientId], references: [id])
  clinicalRules ClinicalRule[]

  @@unique([ingredientId, code])
  @@map("supplement_ingredient_formes")
}

model SupplementSourceReference {
  id        String   @id @default(cuid())
  citation  String   @map("citation")
  lienUrl   String?  @map("lien_url")
  actif     Boolean  @default(true) @map("actif")
  createdAt DateTime @default(now()) @map("created_at")

  clinicalRules        ClinicalRule[]
  functionalThresholds IngredientFunctionalThreshold[]

  @@map("supplement_source_references")
}

model SupplementSafetyAlert {
  id           String   @id @default(cuid())
  code         String   @unique @map("code")
  messageFr    String   @map("message_fr")
  niveauAlerte String   @map("niveau_alerte")
  actif        Boolean  @default(true) @map("actif")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  functionalThresholds IngredientFunctionalThreshold[]

  @@map("supplement_safety_alerts")
}

model ClinicalIntentTag {
  id            String   @id @default(cuid())
  code          String   @unique @map("code")
  labelFr       String   @map("label_fr")
  categorie     String   @map("categorie")
  synonymes     String[] @default([]) @map("synonymes")
  actif         Boolean  @default(true) @map("actif")
  notesInternes String?  @map("notes_internes")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  clinicalRules ClinicalRule[]

  @@index([categorie])
  @@map("clinical_intent_tags")
}

model ClinicalCriterion {
  id        String   @id @default(cuid())
  code      String   @unique @map("code")
  labelFr   String   @map("label_fr")
  categorie String?  @map("categorie")
  actif     Boolean  @default(true) @map("actif")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("clinical_criteria")
}

model FunctionalCategory {
  id          String   @id @default(cuid())
  code        String   @unique @map("code")
  labelFr     String   @map("label_fr")
  description String?  @map("description")
  actif       Boolean  @default(true) @map("actif")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  functionalThresholds IngredientFunctionalThreshold[]

  @@map("functional_categories")
}

model ClinicalRule {
  id                      String @id @default(cuid())
  intentTagId             String @map("intent_tag_id")
  typeRegle               String @map("type_regle")
  poids                   Int    @map("poids")
  justification           String @map("justification")
  conditionSupplementaire Json?  @map("condition_supplementaire")

  ingredientId            String  @map("ingredient_id")
  formePrefereeId         String? @map("forme_preferee_id")
  doseCibleBasse          Float?  @map("dose_cible_basse")
  doseCibleHaute          Float?  @map("dose_cible_haute")
  gradePreuveScientifique String  @map("grade_preuve_scientifique")
  sourceReferenceId       String  @map("source_reference_id")

  versionRegle Int       @default(1) @map("version_regle")
  actif        Boolean   @default(true) @map("actif")
  creeLe       DateTime  @default(now()) @map("cree_le")
  validePar    String?   @map("valide_par")
  valideLe     DateTime? @map("valide_le")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  intentTag       ClinicalIntentTag          @relation(fields: [intentTagId], references: [id])
  ingredient      SupplementIngredient       @relation(fields: [ingredientId], references: [id])
  formePreferee   SupplementIngredientForme? @relation(fields: [formePrefereeId], references: [id])
  sourceReference SupplementSourceReference  @relation(fields: [sourceReferenceId], references: [id])

  @@index([intentTagId])
  @@index([ingredientId])
  @@map("clinical_rules")
}

model IngredientFunctionalThreshold {
  id                       String   @id @default(cuid())
  ingredientId             String   @map("ingredient_id")
  categorieFonctionnelleId String   @map("categorie_fonctionnelle_id")
  seuilDoseBasse           Float?   @map("seuil_dose_basse")
  seuilDoseHaute           Float?   @map("seuil_dose_haute")
  unite                    String   @map("unite")
  contexteAdditionnel      Json?    @map("contexte_additionnel")
  gradePreuveScientifique  String   @map("grade_preuve_scientifique")
  sourceReferenceId        String   @map("source_reference_id")
  basculeRisque            Boolean  @default(false) @map("bascule_risque")
  safetyAlertId            String?  @map("safety_alert_id")
  actif                    Boolean  @default(true) @map("actif")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  ingredient             SupplementIngredient      @relation(fields: [ingredientId], references: [id])
  categorieFonctionnelle FunctionalCategory        @relation(fields: [categorieFonctionnelleId], references: [id])
  sourceReference        SupplementSourceReference @relation(fields: [sourceReferenceId], references: [id])
  safetyAlert            SupplementSafetyAlert?    @relation(fields: [safetyAlertId], references: [id])

  @@index([ingredientId, categorieFonctionnelleId])
  @@map("ingredient_functional_thresholds")
}

model ProtocolReviewFlag {
  id                     String    @id @default(cuid())
  protocolDraftId        String    @map("protocol_draft_id")
  typeFlag               String    @map("type_flag")
  ingredientsConcernes   String[]  @default([]) @map("ingredients_concernes")
  niveauAlerte           String    @map("niveau_alerte")
  message                String    @map("message")
  suggestionAction       String    @map("suggestion_action")
  statut                 String    @default("ouvert") @map("statut")
  justificationPraticien String?   @map("justification_praticien")
  traitePar              String?   @map("traite_par")
  traiteLe               DateTime? @map("traite_le")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@index([protocolDraftId])
  @@map("protocol_review_flags")
}
