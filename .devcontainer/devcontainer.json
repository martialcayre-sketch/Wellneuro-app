{
  "name": "wellneuro-app — Dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "1.1.0"
    }
  },
  "postCreateCommand": "cd web && npm install",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "mounts": [
    "source=${localWorkspaceFolderBasename}-vscode-server,target=/home/node/.vscode-server,type=volume",
    "source=${localWorkspaceFolderBasename}-codex-home,target=/home/node/.codex,type=volume",
    "source=${localWorkspaceFolderBasename}-claude-home,target=/home/node/.claude,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "github.vscode-pull-request-github",
        "openai.chatgpt",
        "anthropic.claude-code"
      ]
    }
  },
  "forwardPorts": [
    3000
  ],
  "portsAttributes": {
    "3000": {
      "label": "Next.js dev",
      "onAutoForward": "notify"
    }
  },
  "remoteEnv": {
    "NODE_ENV": "development",
    "CODEX_HOME": "/home/node/.codex",
    "CLAUDE_HOME": "/home/node/.claude"
  },
  "runArgs": [
    "--init"
  ]
}
