{
  "folders": [
    {
      "path": "."
    }
  ],
  "settings": {
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "editor.formatOnSave": false,
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "eslint.validate": [
      "javascript",
      "html",
      "typescript",
      "typescriptreact"
    ],
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.cwd": "${workspaceFolder}",
    "search.exclude": {
      "**/node_modules": true,
      "**/.git": true,
      "**/.next": true
    },
    "tailwindCSS.includeLanguages": {
      "typescript": "javascript",
      "typescriptreact": "javascript"
    }
  },
  "extensions": {
    "recommendations": [
      "esbenp.prettier-vscode",
      "dbaeumer.vscode-eslint",
      "bradlc.vscode-tailwindcss",
      "davidanson.vscode-markdownlint",
      "eamodio.gitlens",
      "github.copilot",
      "github.copilot-chat",
      "openai.chatgpt",
      "anthropic.claude-code"
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "bootstrap-local",
        "type": "shell",
        "command": "cd web && npm install"
      },
      {
        "label": "bootstrap-mac",
        "type": "shell",
        "command": "bash scripts/bootstrap-mac.sh"
      },
      {
        "label": "bootstrap-mac-system",
        "type": "shell",
        "command": "bash scripts/bootstrap-mac-system.sh"
      },
      {
        "label": "dev-web",
        "type": "shell",
        "command": "cd web && npm run dev",
        "group": "build",
        "isBackground": true,
        "problemMatcher": []
      },
      {
        "label": "type-check",
        "type": "shell",
        "command": "cd web && npm run type-check",
        "group": "test"
      },
      {
        "label": "check-no-secrets",
        "type": "shell",
        "command": "bash scripts/check_no_secrets.sh",
        "group": "test"
      }
    ]
  }
}
